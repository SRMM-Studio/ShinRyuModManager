<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:ShinRyuModManager.UserInterface"
             x:Class="ShinRyuModManager.UserInterface.App"
             RequestedThemeVariant="Default">
    <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.Resources>
        <Color x:Key="SystemAccentColor">#FFD41F1F</Color>
        <Color x:Key="SystemAccentColorLight1">#FFE35A42</Color>
        <Color x:Key="SystemAccentColorLight2">#FFE87F6C</Color>
        <Color x:Key="SystemAccentColorLight3">#FFEEA896</Color>
        <Color x:Key="SystemAccentColorDark1">#FF9E1600</Color>
        <Color x:Key="SystemAccentColorDark2">#FF6B0F00</Color>
        <Color x:Key="SystemAccentColorDark3">#FF380800</Color>
    </Application.Resources>
    
    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml"/>
    </Application.Styles>
</Application>